import tkinter as tk
from transformers import pipeline

# Load pre-trained GPT-2 model
generator = pipeline('text-generation', model='gpt2')

# Function to generate story
def generate_story():
    topic = entry.get()

    if topic == "":
        result_box.delete("1.0", tk.END)
        result_box.insert(tk.END, "Please enter a topic!")
        return

    prompt = f"Once upon a time {topic}"

    # Generate text
    result = generator(prompt, max_length=150, num_return_sequences=1)

    story = result[0]['generated_text']

    result_box.delete("1.0", tk.END)
    result_box.insert(tk.END, story)

# GUI
root = tk.Tk()
root.title("AI Story Generator (GPT-2)")
root.geometry("700x500")

title = tk.Label(root, text="AI Story Generator", font=("Arial", 16, "bold"))
title.pack(pady=10)

entry = tk.Entry(root, width=50, font=("Arial", 12))
entry.pack(pady=10)
entry.insert(0, "Enter story topic...")

btn = tk.Button(root, text="Generate Story", command=generate_story, bg="blue", fg="white")
btn.pack(pady=10)

result_box = tk.Text(root, wrap=tk.WORD, width=80, height=20)
result_box.pack(pady=10)

root.mainloop()
